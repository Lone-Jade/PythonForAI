# ======================================
# 1. Python 项目必须忽略（核心）
# ======================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
*.venv
.venv/

# 数据分析 / 机器学习缓存
*.pkl
*.h5
*.keras
*.npy
*.npz

# 运行结果、日志
*.log
*.tmp
*.temp


# ======================================
# 2. VSCode 编辑器配置（安全同步）
# ======================================
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# 上面的意思：
# 忽略 .vscode 里的缓存、临时文件
# 只同步：你的设置、扩展、运行配置


# ======================================
# 3. 系统垃圾文件（所有系统通用）
# ======================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db


# ======================================
# 4. GitHub 不需要的文件
# ======================================
*.zip
*.rar
*.exe
*.dll
*.png
*.jpg
*.gif
*.pdf


# ======================================
# 5. 你的 TSP / 模拟退火 项目专用
# ======================================
